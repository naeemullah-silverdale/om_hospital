<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_appointment_tree" model="ir.ui.view">
        <field name="name">hospital.appointment.tree</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list string="Appointments" create="1" delete="1" edit="1" default_group_by="state">
                <field name="patient_id"/>
                <field name="appointment_time"/>
                <field name="doctor_id" widget="many2one_avatar"/>
                <field name="booking_date" optional="show"/>
                <field name="activity_ids" widget="list_activity"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge" decoration-info="state == 'in_consultation'"
                       decoration-success="state == 'done'" decoration-danger="state == 'cancel'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Form View with Statusbar and Priority -->
    <record id="view_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"
                           statusbar_visible="draft,in_consultation,done"/>
                </header>
                <sheet>
                    <h2>
                        <field name="priority" widget="priority"/>
                    </h2>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="doctor_id"/>
                            <field name="appointment_time"/>
                            <field name="booking_date"/>
                            <button name="action_test"
                                    type="object"
                                    string="Confirm"
                                    class="btn-primary"/>
                        </group>
                    </group>

                    <notebook>
                        <page string='Prescription'>
                            <group>
                                <field name="prescription" placeholder=" Enter your prescription">

                                </field>
                            </group>
                        </page>

                        <page string="pharmacy">
                            <field name="pharmacy_line_ids">
                                <list>
                                    <field name="product_id"/>
                                    <field name="price_unit"/>
                                    <field name="qty"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="product_id"/>
                                        <field name="price_unit"/>
                                        <field name="qty"/>
                                    </group>
                                </form>

                            </field>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
