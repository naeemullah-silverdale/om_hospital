<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_appointment_tree" model="ir.ui.view">
        <field name="name">hospital.appointment.tree</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list string="Appointments" create="1" delete="1" edit="1">
                <field name="patient_id"/>
                <field name="appointment_time"/>
                <field name="booking_date"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge" decoration-info="state == 'in_consultation'"
                       decoration-success="state == 'done'" decoration-danger="state == 'cancel'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Form View with Statusbar and Priority -->
    <record id="view_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"
                           statusbar_visible="draft,in_consultation,done"/>
                </header>
                <sheet>
                    <h2>
                        <field name="priority" widget="priority"/>
                    </h2>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="appointment_time"/>
                            <field name="booking_date"/>
                            <button name="action_test"
                                    type="object"
                                    string="Confirm"
                                    class="btn-primary"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
